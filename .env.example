# --- Google Gemini (required) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=8192

# --- Auth ---
# Secret used to sign session tokens. Set a long random value in production.
SECRET_KEY=change-me-to-a-long-random-string
TOKEN_TTL_HOURS=168

# --- Database ---
# MySQL is preferred; if it's unreachable the app falls back to a local SQLite
# file automatically (so accounts & history work even without a MySQL server).
# Either set a full SQLAlchemy URL...
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/codegen?charset=utf8mb4
# ...or the individual parts below (used when DATABASE_URL is empty):
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=codegen
MYSQL_PASSWORD=codegen
MYSQL_DATABASE=codegen

# --- App ---
CORS_ORIGINS=*
APP_ENV=development
PORT=8000
